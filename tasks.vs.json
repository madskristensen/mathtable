{
    "version": "0.2.1",
    "tasks": [
        {
            "taskLabel": "Serve docs (dotnet-serve)",
            "appliesTo": "docs/index.html",
            "type": "launch",
            "command": "dotnet-serve",
            "args": [
                "--directory",
                "./docs",
                "--port",
                "8080",
                "--open-browser"
            ],
            "workingDirectory": "${workspaceRoot}"
        }
    ]
}